<?xml version="1.0" ?>
<odoo>
    <record id="crm_lead_view_form_inherit_product" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit.product.lines</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form" />
        <field name="arch" type="xml">
            
            <xpath expr="//button[@name='action_sale_quotation_new']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//header" position="inside">
                <button name="action_make_quotation" 
                        string="New Quotation" 
                        type="object" 
                        class="oe_highlight" 
                        invisible="type == 'lead' or not lead_line_ids"/>
            </xpath>
            
            <page name="extra" position="before">
                <page name="products" string="Products">
                    <field name="lead_line_ids" />
                </page>
            </page>
        </field>
    </record>
</odoo>